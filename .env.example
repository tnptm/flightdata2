# PostgreSQL
POSTGRES_USER=flightdata
POSTGRES_PASSWORD=changeme
POSTGRES_DB=flightdata

# Derived by the app container (do not change the host — it matches the compose service name)
DATABASE_URL=postgresql://flightdata:changeme@db:5432/flightdata

# Polling interval in seconds (default: 300)
POLL_INTERVAL=300

# Path to OpenSky credentials file inside the container
OPENSKY_CREDENTIALS=credentials.json

# Logging
LOG_FILE=logs/tracker.log
LOG_LEVEL=INFO
